node_modules/
dist/
.next/

# Never commit local environment files anywhere in the tree. The only
# exception is the `.env.example` templates committed alongside packages.
**/.env
**/.env.*
!**/.env.example

.DS_Store
*.log
CLAUDE.md
next-env.d.ts
# Next.js example templates ship a tracked next-env.d.ts so cloned
# projects pick up the right types before the first `next dev` run.
!examples/*/next-env.d.ts
tsconfig.tsbuildinfo

# Per-package LICENSE/NOTICE are copied in by `prepack` from the repo root.
# Keep only the canonical copies at the repo root in version control.
packages/*/LICENSE
packages/*/NOTICE
