{
  "name": "js-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Reactor JS SDK - client libraries and tools for building real-time AI video applications",
  "scripts": {
    "build": "pnpm --filter @reactor-team/js-sdk build",
    "test:unit": "pnpm --filter @reactor-team/js-sdk test:unit",
    "test:integration": "pnpm --filter @reactor-team/js-sdk test:integration",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint:secrets": "git ls-files -z | xargs -0 secretlint --maskSecrets",
    "lint:license": "./scripts/check-license.sh",
    "local-build": "pnpm --filter @reactor-team/js-sdk build && echo '\n@reactor-team/js-sdk built. Link with:\n  pnpm link '$(realpath packages/js-sdk)",
    "install:create-app": "pnpm --filter create-reactor-app install-cli"
  },
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.4",
    "prettier": "^3.8.4",
    "secretlint": "^13.0.2"
  }
}
