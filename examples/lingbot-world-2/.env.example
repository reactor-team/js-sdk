# ============================================================================
# lingbot-world-2 — example environment. Copy to .env.local and fill in.
#
# Only the Next.js app reads .env.local. The coordinator (Node) and the AI
# director (Python) read their vars from the SHELL environment (set by their
# .bat launchers) — they are listed here as reference, not because .env.local
# feeds them. Anything NEXT_PUBLIC_* is exposed to the browser bundle.
# ============================================================================

# ── Next.js app (reads .env.local) ─────────────────────────────────────────

# REQUIRED for cloud video. Server-side Reactor key, exchanged for session JWTs
# by app/api/reactor/token/route.ts. Get one at reactor.inc/account/api-keys.
REACTOR_API_KEY=rk_your_api_key_here

# Video backend the SDK connects to. Unset = Reactor cloud (default below).
# Set to http://localhost:8080 to use a LOCAL server (run_reactor_server.bat).
# NEXT_PUBLIC_COORDINATOR_URL=https://api.reactor.inc

# Director coordinator WebSocket (shared History for Player/Director). Enables
# the Director panel + AI director. Unset = single-machine, no coordinator.
NEXT_PUBLIC_COORDINATOR_WS=ws://localhost:8090

# Optional FlashDream local WebRTC backend for the /flashdream page. Point at a
# running flashdream_public server. Unset = disabled (Reactor path unaffected).
# NEXT_PUBLIC_FLASHDREAM_URL=http://localhost:8089

# ── Frame tap / archive (Next route + director + local engine share these) ──

# File the AI director watches for the latest frame. Default: coordinator/frame.png
# (resolved from the app's working dir). Set on BOTH the Next server and the
# director if you override it, or they'll point at different files.
# LINGBOT_FRAME_TAP=C:\workspace\world\REACTOR_js-sdk\examples\lingbot-world-2\coordinator\frame.png

# DEBUG: keep every browser-tapped frame (frame_<epoch-ms>.jpg) so you can replay
# what the director saw. Unset = disabled (only the single frame.png is kept).
LINGBOT_FRAME_ARCHIVE=C:\tmp\director_frames
# How many archived frames to keep (oldest pruned). Default 100.
# LINGBOT_FRAME_ARCHIVE_MAX=100

# ── Coordinator (Node — set in the shell / run_coordinator.bat) ─────────────
# COORDINATOR_PORT=8090        # WebSocket port (default 8090)
# COMMAND_LOG=commands.jsonl   # append every op as one JSON line (audit)
# COORDINATOR_DEBUG=1          # 1 = log every state change (default on); 0 = quiet

# ── AI director (Python — set in the shell / run_ai.bat) ────────────────────
# NVIDIA_API_KEY=nvapi-...     # REQUIRED for the AI director (billed NIM calls)
# SCENE=../lib/lingbot-cases/jet-ski-cruise.json  # preload a scene (else follows UI)
# FRAME=frame.png              # frame file to watch (falls back to LINGBOT_FRAME_TAP)

# ── Local video server (Python engine.py — set in the shell) ────────────────
# LINGBOT_FRAME_TAP=...        # where engine.py writes live frames (see above)
# LINGBOT_FRAME_TAP_EVERY=5    # write 1 of every N generated frames (default 5)
