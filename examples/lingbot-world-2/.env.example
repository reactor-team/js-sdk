REACTOR_API_KEY=rk_your_api_key_here

# Optional — Reactor API base URL. Defaults to https://api.reactor.inc
# NEXT_PUBLIC_COORDINATOR_URL=

# Optional — opt-in flashdream local WebRTC backend for the /flashdream page.
# Point at a running flashdream_public lingbot.webrtc.server. Unset = disabled
# (the default Reactor path is unaffected).
# NEXT_PUBLIC_FLASHDREAM_URL=http://localhost:8089
