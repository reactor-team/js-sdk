# Server-side Reactor API key, used by /api/reactor/token to mint
# short-lived session JWTs. Create one at
# https://www.reactor.inc/dashboard/account?section=api-keys
REACTOR_API_KEY=rk_your_api_key_here

# Optional: point the SDK at a non-production Reactor API.
# NEXT_PUBLIC_REACTOR_API_URL=https://api.reactor.inc
