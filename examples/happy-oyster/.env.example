# HappyOyster needs one thing configured: your Reactor API key. Everything
# else the model hands the browser at runtime.

# ── Required ─────────────────────────────────────────────────────────────────

# The Reactor control plane (sessions, world builds, state snapshots, and the
# per-session travel credentials the model broadcasts). Your account API key,
# starts with rk_. Server-side only — the app/api/reactor/token route exchanges
# it for short-lived browser JWTs, the key itself never ships to the browser.
# Get one at https://www.reactor.inc/account/api-keys
REACTOR_API_KEY=rk_your_api_key_here

# ── Local development only ───────────────────────────────────────────────────

# Point the control plane at a different Reactor API. Defaults to
# https://api.reactor.inc, or to http://localhost:8080 when
# NEXT_PUBLIC_HO_LOCAL_RUNTIME=1 below is set.
# NEXT_PUBLIC_COORDINATOR_URL=

# Talk straight to a happy-oyster model served by the Reactor runtime (e.g. a
# local backend on :8080), skipping the Coordinator: no REACTOR_API_KEY and no
# JWT exchange.
# NEXT_PUBLIC_HO_LOCAL_RUNTIME=1
