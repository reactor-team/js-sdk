# HappyOyster needs one thing configured: your Reactor API key.

# ── Required ─────────────────────────────────────────────────────────────────

# Your Reactor account API key, starts with rk_. Server-side only — the
# app/api/reactor/token route exchanges it for short-lived browser JWTs, so the
# key itself never ships to the browser.
# Get one at https://www.reactor.inc/account/api-keys
REACTOR_API_KEY=rk_your_api_key_here

# ── Local development only ───────────────────────────────────────────────────

# Point the app at a different Reactor API. Defaults to https://api.reactor.inc.
# NEXT_PUBLIC_COORDINATOR_URL=

# Talk straight to a happy-oyster model served by the Reactor runtime (adventure
# on :8080, director on :8081), skipping the Coordinator: no REACTOR_API_KEY and
# no JWT exchange.
# NEXT_PUBLIC_HO_LOCAL_RUNTIME=1
