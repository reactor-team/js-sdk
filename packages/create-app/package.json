  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/reactor-team/js-sdk.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@reactor-team/js-sdk": "^2.2.2",
    "inquirer": "^13.4.3",
    "chalk": "^5.3.0",
