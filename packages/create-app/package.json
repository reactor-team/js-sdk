  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsup": "^8.0.1",
    "@types/node": "^25.9.1"
  },
  "scripts": {
    "prepack": "cp ../../LICENSE ../../NOTICE .",
    "postpack": "rm -f LICENSE NOTICE",
    "build": "tsup",
    "install-cli": "tsup && pnpm link --global && echo '\n✅ create-reactor-app linked globally. Run it with:\n\n  create-reactor-app\n'"
