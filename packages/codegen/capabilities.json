{
    "protocol_version": "1.3",
    "tracks": [
        {
            "name": "main_video",
            "kind": "video",
            "direction": "recvonly"
        }
    ],
    "commands": [
        {
            "name": "set_prompt",
            "description": "Set and encode scene prompt",
            "schema": {
                "prompt": {
                    "type": "string",
                    "default": ""
                }
            }
        },
        {
            "name": "set_image",
            "description": "Set starting frame from base64 and VAE-encode",
            "schema": {
                "image": {
                    "type": "string",
                    "default": ""
                }
            }
        },
        {
            "name": "schedule_prompt",
            "description": "Schedule prompt change at a specific chunk",
            "schema": {
                "prompt": {
                    "type": "string",
                    "default": ""
                },
                "chunk": {
                    "type": "integer",
                    "default": 0,
                    "minimum": 0
                }
            }
        },
        {
            "name": "start",
            "description": "Begin generation (requires prompt)",
            "schema": {}
        },
        {
            "name": "pause",
            "description": "Pause generation after current chunk",
            "schema": {}
        },
        {
            "name": "resume",
            "description": "Resume paused generation",
            "schema": {}
        },
        {
            "name": "reset",
            "description": "Reset generation and return to waiting state",
            "schema": {}
        },
        {
            "name": "set_image_strength",
            "description": "Set image_strength",
            "schema": {
                "image_strength": {
                    "type": "number",
                    "default": 1.0,
                    "description": "Image conditioning strength",
                    "minimum": 0.0,
                    "maximum": 1.0
                }
            }
        },
        {
            "name": "set_seed",
            "description": "Set seed",
            "schema": {
                "seed": {
                    "type": "integer",
                    "default": 0,
                    "description": "RNG seed (-1 for random)"
                }
            }
        },
        {
            "name": "set_sr_scale",
            "description": "Set sr_scale",
            "schema": {
                "sr_scale": {
                    "type": "string",
                    "default": "2x",
                    "description": "Super-resolution scale",
                    "enum": [
                        "off",
                        "2x",
                        "4x"
                    ]
                }
            }
        }
    ],
    "messages": [
        {
            "name": "prompt_accepted",
            "schema": {
                "prompt": {
                    "type": "string"
                }
            }
        },
        {
            "name": "image_accepted",
            "schema": {
                "width": {
                    "type": "integer"
                },
                "height": {
                    "type": "integer"
                }
            }
        },
        {
            "name": "conditions_ready",
            "schema": {
                "has_prompt": {
                    "type": "boolean"
                },
                "has_image": {
                    "type": "boolean"
                }
            }
        },
        {
            "name": "generation_started",
            "schema": {
                "prompt": {
                    "type": "string"
                },
                "chunk_index": {
                    "type": "integer"
                }
            }
        },
        {
            "name": "chunk_complete",
            "schema": {
                "chunk_index": {
                    "type": "integer"
                },
                "frames_emitted": {
                    "type": "integer"
                },
                "active_prompt": {
                    "type": "string"
                }
            }
        },
        {
            "name": "generation_paused",
            "schema": {
                "chunk_index": {
                    "type": "integer"
                }
            }
        },
        {
            "name": "generation_resumed",
            "schema": {
                "chunk_index": {
                    "type": "integer"
                }
            }
        },
        {
            "name": "command_error",
            "schema": {
                "command": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                }
            }
        }
    ],
    "emission_fps": 30
}