{
  "name": "@reactor-team/codegen",
  "version": "0.1.0",
  "description": "Code generator for strongly-typed Reactor model SDKs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "reactor-codegen": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen:test": "tsx src/cli.ts --schema schema.json --sdk-version 2.9.3 --output .generated/example"
  },
  "keywords": [
    "reactor",
    "codegen",
    "sdk"
  ],
  "defaultSdkVersion": "2.9.3",
  "author": "Reactor Technologies, Inc.",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
